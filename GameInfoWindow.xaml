<Window x:Class="GameRecommender.GameInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game info"
        Width="620"
        Height="720"
        MinWidth="460"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="#121821"
        Loaded="Window_Loaded">
    <Window.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#EEF3F8"/>
        <SolidColorBrush x:Key="TextBrushDarker" Color="#A9B5C6"/>
        <SolidColorBrush x:Key="ThemeSurfaceBrush" Color="#18212D"/>
        <SolidColorBrush x:Key="ThemeSurfaceHoverBrush" Color="#202B3A"/>
        <SolidColorBrush x:Key="ThemeAccentBrush" Color="#65D2C5"/>
        <SolidColorBrush x:Key="ThemeAccentSoftBrush" Color="#23434A"/>
        <SolidColorBrush x:Key="ThemeDangerBrush" Color="#CF737C"/>
        <SolidColorBrush x:Key="ThemeDangerHoverBrush" Color="#F08A95"/>
        <SolidColorBrush x:Key="NormalBorderBrush" Color="#2B3646"/>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource ThemeAccentBrush}"/>
            <Setter Property="Margin" Value="0,16,0,6"/>
        </Style>
        <Style x:Key="MetaText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrushDarker}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ThemeSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource NormalBorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="MinWidth" Value="76"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ThemeAccentSoftBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource ThemeAccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="{StaticResource ThemeDangerBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource ThemeDangerHoverBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource ThemeDangerHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource ThemeSurfaceBrush}"
                BorderBrush="{StaticResource NormalBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,10">
            <DockPanel LastChildFill="False">
                <Button x:Name="CloseButton" Content="Close" DockPanel.Dock="Right" Click="CloseButton_Click"/>
                <Button x:Name="RejectButton" Content="Reject" DockPanel.Dock="Right" Style="{StaticResource DangerButton}" Click="RejectButton_Click"/>
                <Button x:Name="LaunchButton" Content="Launch" DockPanel.Dock="Right" Click="LaunchButton_Click"/>
                <Button x:Name="GoToLibraryButton" Content="Go to library" DockPanel.Dock="Right" Click="GoToLibraryButton_Click"/>
                <Button x:Name="TrailerButton" Content="Open trailer" DockPanel.Dock="Right" Click="TrailerButton_Click"/>
            </DockPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="18">
                <TextBlock x:Name="TitleText"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="SourceText"
                           Style="{StaticResource MetaText}"
                           Margin="0,4,0,0"/>

                <TextBlock Text="Why this recommendation" Style="{StaticResource SectionTitle}"/>
                <StackPanel x:Name="ReasonsPanel"/>

                <TextBlock Text="Score breakdown" Style="{StaticResource SectionTitle}"/>
                <UniformGrid Columns="2" x:Name="ScoresPanel"/>

                <TextBlock Text="Metadata" Style="{StaticResource SectionTitle}"/>
                <StackPanel x:Name="MetadataPanel"/>

                <TextBlock Text="Description" Style="{StaticResource SectionTitle}"/>
                <TextBlock x:Name="DescriptionText"
                           Style="{StaticResource MetaText}"
                           MaxHeight="260"/>

                <TextBlock Text="Links" Style="{StaticResource SectionTitle}"/>
                <TextBlock x:Name="LinksStatusText"
                           Style="{StaticResource MetaText}"
                           Margin="0,0,0,8"/>
                <WrapPanel x:Name="LinksPanel"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
